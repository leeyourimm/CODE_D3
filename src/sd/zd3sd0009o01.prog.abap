*&---------------------------------------------------------------------*
*& Module SET_TABSTRIP_0200 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE set_tabstrip_0200 OUTPUT.

  IF tab-activetab IS INITIAL.
    tab-activetab = 'FC1'.
  ENDIF.

  CASE tab-activetab.
    WHEN 'FC1'.
      gv_subscreen = '0201'.
    WHEN 'FC2'.
      gv_subscreen = '0202'.

    WHEN OTHERS.
      gv_subscreen = '0201'.

  ENDCASE.

ENDMODULE.
